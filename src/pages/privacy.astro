---
import BaseLayout from "../layouts/BaseLayout.astro";
const title = "Privacy Policy | NiO Pictures — Katy TX";
const description = "Privacy Policy for NiO Pictures. Learn how we collect, use, and protect your information when you visit niopictures.com or contact us.";
const canonical = "https://niopictures.com/privacy.html";
const ogImage = "https://niopictures.com/assets/images/og-home.webp";
const extraHead = `<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://niopictures.com/"},
    {"@type": "ListItem", "position": 2, "name": "Privacy Policy", "item": "https://niopictures.com/privacy.html"}
  ]
}
</script>`;
---

<BaseLayout title={title} description={description} canonical={canonical} ogImage={ogImage} noIndex={true}>
  <Fragment slot="head" set:html={extraHead} />
<a href="#main-content" class="skip-link" style="position:absolute;top:-40px;left:1rem;background:var(--gold);color:var(--black);padding:0.5rem 1rem;border-radius:2px;font-family:var(--font-accent);font-size:0.7rem;letter-spacing:.1em;text-transform:uppercase;z-index:9999;transition:top var(--dur-fast);" onfocus="this.style.top='1rem'" onblur="this.style.top='-40px'">Skip to main content</a>

  <nav class="nav" role="navigation" aria-label="Main navigation">
    <a href="/" class="nav-logo">Ni<span>O</span> Pictures</a>
    <div class="nav-links">
      <a href="/event-photography-katy-tx.html">Events</a>
      <a href="/family-photography-katy-tx.html">Family</a>
      <a href="/blog.html">Blog</a>
      <a href="/portfolio.html">Portfolio</a>
      <a href="/about.html">About</a>
      <a href="/contact.html">Contact</a>
    </div>
    <a href="https://niopictures.pixieset.com/booking/" target="_blank" rel="noopener noreferrer" class="btn btn-primary nav-cta">Book Now</a>
    <button class="nav-toggle" aria-label="Open menu" aria-expanded="false"><span></span><span></span><span></span></button>
  </nav>

  <div class="nav-mobile" role="dialog" aria-label="Mobile navigation">
    <a href="/event-photography-katy-tx.html">Events</a>
    <a href="/family-photography-katy-tx.html">Family</a>
    <a href="/blog.html">Blog</a>
    <a href="/portfolio.html">Portfolio</a>
    <a href="/about.html">About</a>
    <a href="/contact.html">Contact</a>
    <a href="https://niopictures.pixieset.com/booking/" target="_blank" rel="noopener noreferrer" class="nav-mobile-cta">Book a Session →</a>
  </div>

  <main id="main-content">

  <div style="padding: calc(var(--section-pad) + 4rem) 0 3rem; border-bottom: 1px solid var(--border-light);">
    <div class="container" style="max-width: 760px;">
      <p class="eyebrow" style="margin-bottom:1rem;">Legal</p>
      <div class="gold-line"></div>
      <h1 class="display-xl" style="margin-bottom:0.75rem;">Privacy Policy</h1>
      <p class="body-lg">NiO Pictures is committed to protecting your privacy. This policy explains what information we collect, how we use it, and your rights.</p>
    </div>
  </div>

  <div class="legal-body">
    <span class="effective-date">Effective date: March 1, 2026 &nbsp;·&nbsp; NiO Pictures, Katy, Texas</span>

    <h2 class="display-md">1. Who We Are</h2>
    <p>NiO Pictures is a photography business operated by Palanivel, based in Katy, Texas. We provide event and family photography services to clients in Katy, Houston, Sugar Land, Cypress, Richmond, and surrounding areas.</p>
    <p><strong style="color:var(--cream);">Contact:</strong> niopictureskaty@gmail.com &nbsp;·&nbsp; 281-409-3585 &nbsp;·&nbsp; Katy, TX</p>

    <div class="legal-divider"></div>

    <h2 class="display-md">2. Information We Collect</h2>

    <h3 class="display-sm">Information you provide directly</h3>
    <p>When you submit a contact or booking inquiry on our website, we collect:</p>
    <ul>
      <li>Your name</li>
      <li>Your email address</li>
      <li>Your phone number (optional)</li>
      <li>The message or session details you provide</li>
    </ul>
    <p>This information is used solely to respond to your inquiry and discuss photography services. It is not stored on our servers — it is sent directly to our email inbox via Formspree (our form processing service).</p>

    <h3 class="display-sm">Information collected automatically</h3>
    <p>When you visit niopictures.com, Google Analytics 4 (GA4) automatically collects:</p>
    <ul>
      <li>Pages you visit and how long you spend on them</li>
      <li>How you arrived at the site (search, direct, social media)</li>
      <li>Your general geographic location (city/country level — not your precise address)</li>
      <li>Device type, browser, and operating system</li>
      <li>Approximate session duration and interactions</li>
    </ul>
    <p>This data is aggregated and anonymized. We cannot identify you personally from this data. Google Analytics uses cookies to distinguish between visits.</p>

    <div class="legal-divider"></div>

    <h2 class="display-md">3. How We Use Your Information</h2>
    <ul>
      <li>To respond to photography inquiries and booking requests</li>
      <li>To understand how visitors use our website so we can improve it</li>
      <li>To understand which services and content are most useful to our clients</li>
    </ul>
    <p>We do not use your information for automated decision-making or profiling.</p>

    <div class="legal-divider"></div>

    <h2 class="display-md">4. Google Analytics</h2>
    <p>This website uses Google Analytics 4, provided by Google LLC. Google Analytics collects data through cookies placed on your device. This data is processed by Google and subject to <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Google's Privacy Policy</a>.</p>
    <p>You can opt out of Google Analytics tracking by installing the <a href="https://tools.google.com/dlpage/gaoptout" target="_blank" rel="noopener noreferrer">Google Analytics Opt-Out Browser Add-on</a>, or by using your browser's privacy settings to block cookies.</p>
    <p>We have configured Google Analytics with IP anonymization enabled. We do not share Google Analytics data with third parties.</p>

    <div class="legal-divider"></div>

    <h2 class="display-md">5. Cookies</h2>
    <p>Our website uses the following cookies:</p>
    <ul>
      <li><strong style="color:var(--cream);">Google Analytics cookies</strong> (_ga, _gid, _gat) — used to distinguish visitors and measure site usage. These expire after 2 years (_ga) or 24 hours (_gid).</li>
      <li><strong style="color:var(--cream);">Session preference</strong> — a small sessionStorage entry that remembers whether you have seen the chat widget, so it doesn't re-appear on every page. This is not a cookie and is not sent to any server.</li>
    </ul>
    <p>You can control cookies through your browser settings. Disabling cookies may affect some website functionality.</p>

    <div class="legal-divider"></div>

    <h2 class="display-md">6. Third-Party Services</h2>
    <p>We use the following third-party services that may process your data:</p>
    <ul>
      <li><strong style="color:var(--cream);">Google Analytics</strong> (Alphabet Inc.) — website analytics</li>
      <li><strong style="color:var(--cream);">Formspree</strong> — contact and booking form processing</li>
      <li><strong style="color:var(--cream);">Pixieset</strong> — online gallery and print ordering platform</li>
      <li><strong style="color:var(--cream);">Cloudflare</strong> — website hosting and security</li>
      <li><strong style="color:var(--cream);">Google Fonts</strong> — typography loaded from Google's CDN</li>
    </ul>
    <p>Each of these services has its own privacy policy. We encourage you to review them if you have concerns.</p>

    <div class="legal-divider"></div>

    <h2 class="display-md">7. Data Sharing & Sale</h2>
    <p>We do not sell, rent, or trade your personal information to any third party. We do not share your contact details with other businesses or advertisers.</p>
    <p>We may disclose information if required to do so by law or in response to a valid legal process.</p>

    <div class="legal-divider"></div>

    <h2 class="display-md">8. Data Retention</h2>
    <p>Contact form submissions are retained in our email inbox as long as is necessary to manage our correspondence. You may request deletion at any time by emailing us at niopictureskaty@gmail.com.</p>
    <p>Google Analytics data is retained for 14 months by default, after which it is automatically deleted by Google.</p>

    <div class="legal-divider"></div>

    <h2 class="display-md">9. Your Rights</h2>
    <p>You have the right to:</p>
    <ul>
      <li>Ask what personal data we hold about you</li>
      <li>Request correction or deletion of your data</li>
      <li>Opt out of Google Analytics tracking</li>
      <li>Withdraw consent at any time where consent is the basis for processing</li>
    </ul>
    <p>To exercise any of these rights, email us at <a href="mailto:niopictureskaty@gmail.com">niopictureskaty@gmail.com</a>. We will respond within 30 days.</p>

    <div class="legal-divider"></div>

    <h2 class="display-md">10. Children's Privacy</h2>
    <p>Our website is not directed at children under 13. We do not knowingly collect personal information from children. If you believe a child has submitted information through our forms, please contact us and we will delete it promptly.</p>

    <div class="legal-divider"></div>

    <h2 class="display-md">11. Changes to This Policy</h2>
    <p>We may update this Privacy Policy from time to time. Changes will be posted on this page with an updated effective date. Continued use of the website after changes are posted constitutes your acceptance of the updated policy.</p>

    <div class="legal-divider"></div>

    <h2 class="display-md">12. Contact Us</h2>
    <p>For privacy-related questions or requests, contact us at:</p>
    <p>
      <strong style="color:var(--cream);">NiO Pictures</strong><br>
      Katy, Texas, USA<br>
      <a href="mailto:niopictureskaty@gmail.com">niopictureskaty@gmail.com</a><br>
      <a href="tel:+12814093585">281-409-3585</a>
    </p>

    <div style="margin-top:3rem; padding:1.5rem; background:var(--surface); border:1px solid var(--border-light); border-radius:2px;">
      <p style="margin:0; font-size:0.85rem; color:var(--muted);">See also: <a href="/terms.html">Terms of Service</a> &nbsp;·&nbsp; <a href="/contact.html">Contact Us</a> &nbsp;·&nbsp; <a href="/">Back to Home</a></p>
    </div>
  </div>

  </main>

  
</BaseLayout>
