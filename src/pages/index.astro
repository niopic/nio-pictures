---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";

import aboutPortrait from "../assets/images/home/home-hero-2.jpg";
import aboutMain from "../assets/images/home/home-hero-1.jpg";
import eventsPanel from "../assets/images/home/home-panel-1.jpg";
import familyPanel from "../assets/images/home/home-panel-2.jpg";
import eventsHero from "../assets/images/home/home-hero-3.jpg";
import familyHero from "../assets/images/home/home-hero-4.jpg";
import gridEvents from "../assets/images/home/home-grid-1.jpg";
import gridFamily from "../assets/images/home/home-grid-2.jpg";
import gridPortrait from "../assets/images/home/home-grid-3.jpg";
---

<BaseLayout
  title="NiO Pictures | Event & Family Photographer in Katy TX | Houston Area"
  description="NiO Pictures — event & family photographer in Katy TX. Corporate events, Indian celebrations, heirloom portraits. Katy, Cypress, Houston, Sugar Land & Richmond."
  canonical="https://niopictures.com/"
  ogImage="https://niopictures.com/assets/images/og-home.webp"
  deferComponentsCss={true}
>
  <fragment slot="head">
    <style is:inline>
      :root {
        --black: #161412;
        --gold: #c5a572;
        --cream: #f0e8d8;
        --muted: #a89880;
        --border: rgba(197, 165, 114, 0.15);
        --border-light: rgba(197, 165, 114, 0.08);
        --font-display: "Cormorant Garamond", Georgia, serif;
        --font-body: system-ui, sans-serif;
        --font-accent: "Cinzel", Georgia, serif;
        --container: 1200px;
        --gutter: clamp(1.25rem, 5vw, 2.5rem);
      }
      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }
      body {
        background: var(--black);
        color: var(--cream);
        font-family: var(--font-body);
        font-weight: 300;
        line-height: 1.7;
        overflow-x: hidden;
      }
      a {
        text-decoration: none;
        color: inherit;
      }
      .container {
        width: 100%;
        max-width: var(--container);
        margin: 0 auto;
        padding: 0 var(--gutter);
      }
      .display-xl {
        font-family: var(--font-display);
        font-size: clamp(2.8rem, 7vw, 5.5rem);
        font-weight: 300;
        line-height: 1.08;
        letter-spacing: -0.01em;
      }
      .eyebrow {
        font-family: var(--font-accent);
        font-size: clamp(0.65rem, 1.2vw, 0.75rem);
        font-weight: 400;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--gold);
      }
      .body-sm {
        font-size: 0.875rem;
        font-weight: 300;
        line-height: 1.7;
      }
      .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        font-family: var(--font-accent);
        font-size: 0.7rem;
        font-weight: 500;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        padding: 0.9rem 2rem;
        border: 1px solid transparent;
        border-radius: 2px;
        position: relative;
        overflow: hidden;
      }
      .btn-primary {
        background: var(--gold);
        color: var(--black);
        border-color: var(--gold);
      }
      .btn-outline {
        background: transparent;
        color: var(--cream);
        border-color: rgba(240, 232, 216, 0.35);
      }
      .btn-gold-outline {
        background: transparent;
        color: var(--gold);
        border-color: var(--gold);
      }
      .btn-arrow::after {
        content: "→";
        font-family: var(--font-body);
        font-size: 0.85rem;
      }
      .nav {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 1000;
        padding: 1.5rem var(--gutter);
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .nav::before {
        content: "";
        position: absolute;
        inset: 0;
        background: transparent;
        border-bottom: 1px solid transparent;
        pointer-events: none;
      }
      .nav-logo {
        font-family: var(--font-accent);
        font-size: 1.1rem;
        font-weight: 500;
        letter-spacing: 0.18em;
        color: var(--cream);
        text-transform: uppercase;
        position: relative;
        z-index: 1;
      }
      .nav-logo span {
        color: var(--gold);
      }
      .nav-links {
        display: flex;
        align-items: center;
        gap: 2.5rem;
        position: relative;
        z-index: 1;
      }
      .nav-links a {
        font-family: var(--font-accent);
        font-size: 0.65rem;
        font-weight: 400;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--muted);
        position: relative;
        -webkit-tap-highlight-color: transparent;
      }
      .nav-links a.active,
      .nav-links a:hover {
        color: var(--cream);
      }
      .nav-cta {
        position: relative;
        z-index: 1;
      }
      .nav-toggle,
      .nav-mobile {
        display: none;
      }
      .hero {
        position: relative;
        min-height: 100svh;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
      }
      .hero-bg {
        position: absolute;
        inset: 0;
        background-image: url("/assets/images/hero-home.webp");
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        transform: scale(1);
      }
      .hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
          160deg,
          rgba(22, 20, 18, 0.72) 0%,
          rgba(22, 20, 18, 0.55) 40%,
          rgba(22, 20, 18, 0.75) 100%
        );
      }
      .hero-content {
        position: relative;
        z-index: 2;
        text-align: center;
        max-width: 820px;
        padding: 0 var(--gutter);
      }
      .hero-content .eyebrow {
        margin-bottom: 1.5rem;
      }
      .hero-title em,
      .display-xl em {
        font-style: italic;
        color: var(--gold);
      }
      .hero-subtitle {
        font-size: clamp(0.95rem, 1.8vw, 1.1rem);
        font-weight: 300;
        color: var(--muted);
        max-width: 520px;
        margin: 0 auto 2.5rem;
        line-height: 1.8;
      }
      .hero-actions {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1rem;
        flex-wrap: wrap;
      }
      .hero-scroll {
        position: absolute;
        bottom: 2.5rem;
        left: 50%;
        transform: translateX(-50%);
        z-index: 2;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        cursor: pointer;
      }
      .hero-scroll span {
        font-family: var(--font-accent);
        font-size: 0.6rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--muted);
      }
      .scroll-line {
        width: 1px;
        height: 40px;
        background: linear-gradient(to bottom, var(--gold), transparent);
      }
      @media (max-width: 768px) {
        .nav-links,
        .nav-cta {
          display: none;
        }
        .nav-toggle {
          display: flex;
          flex-direction: column;
          gap: 5px;
          padding: 4px;
          position: relative;
          z-index: 1;
        }
        .nav-toggle span {
          display: block;
          width: 24px;
          height: 1px;
          background: var(--cream);
        }
        .display-xl {
          font-size: clamp(2.2rem, 8vw, 2.8rem);
        }
        .hero-bg {
          background-image: url("/assets/images/hero-home-mobile.webp");
        }
      }
      @media (max-width: 480px) {
        .hero-actions {
          flex-direction: column;
          align-items: center;
        }
        .display-xl {
          font-size: 2rem;
        }
      }
      .feature-card-group {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 3rem;
        max-width: 920px;
        margin: 0 auto;
      }
      @media (max-width: 768px) {
        .feature-card-group {
          grid-template-columns: 1fr;
          gap: 2rem;
        }
      }
      @media (max-width: 480px) {
        .feature-card-group {
          gap: 1.5rem;
        }
      }
    </style>
    <link
      rel="preload"
      as="image"
      href="/assets/images/hero-home-mobile.webp"
      media="(max-width: 768px)"
      fetchpriority="high"
    />
    <link
      rel="preload"
      as="image"
      href="/assets/images/hero-home.webp"
      media="(min-width: 769px)"
      fetchpriority="high"
    />
