---
import BaseLayout from "../layouts/BaseLayout.astro";
const title = "Page Not Found | NiO Pictures";
const description = "The page you're looking for doesn't exist. Return to NiO Pictures — event and family photographer in Katy, TX.";
const canonical = "https://niopictures.com/404.html";
const ogImage = "https://niopictures.com/assets/images/og-home.webp";
const extraHead = `<script type="application/ld+json">
{
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	"itemListElement": [
		{"@type": "ListItem", "position": 1, "name": "Home", "item": "https://niopictures.com/"},
		{"@type": "ListItem", "position": 2, "name": "Page Not Found"}
	]
}
</script>`;
---

<BaseLayout title={title} description={description} canonical={canonical} ogImage={ogImage} noIndex={true}>
	<Fragment slot="head" set:html={extraHead} />
	<a href="#main-content" class="skip-link" style="position:absolute;top:-40px;left:1rem;background:var(--gold);color:var(--black);padding:0.5rem 1rem;border-radius:2px;font-family:var(--font-accent);font-size:0.7rem;letter-spacing:.1em;text-transform:uppercase;z-index:9999;transition:top var(--dur-fast);" onfocus="this.style.top='1rem'" onblur="this.style.top='-40px'">Skip to main content</a>

	<nav class="nav" role="navigation" aria-label="Main navigation">
		<a href="/" class="nav-logo">Ni<span>O</span> Pictures</a>
		<div class="nav-links">
			<a href="/event-photography-katy-tx.html">Events</a>
			<a href="/family-photography-katy-tx.html">Family</a>
			<a href="/portfolio.html">Portfolio</a>
			<a href="/about.html">About</a>
			<a href="/blog.html">Blog</a>
			<a href="/contact.html">Contact</a>
		</div>
		<a href="https://niopictures.pixieset.com/booking/" target="_blank" rel="noopener noreferrer" class="btn btn-primary nav-cta">Book Now</a>
		<button class="nav-toggle" aria-label="Open menu" aria-expanded="false"><span></span><span></span><span></span></button>
	</nav>

	<div class="nav-mobile" role="dialog" aria-label="Mobile navigation">
		<a href="/event-photography-katy-tx.html">Events</a>
		<a href="/family-photography-katy-tx.html">Family</a>
		<a href="/portfolio.html">Portfolio</a>
		<a href="/about.html">About</a>
		<a href="/blog.html">Blog</a>
		<a href="/contact.html">Contact</a>
		<a href="https://niopictures.pixieset.com/booking/" target="_blank" rel="noopener noreferrer" class="nav-mobile-cta">Book a Session →</a>
	</div>

	<main id="main-content">
		<section style="min-height:80svh; display:flex; align-items:center; justify-content:center; text-align:center; padding: var(--section-pad) var(--gutter);">
			<div>
				<p style="font-family:var(--font-display);font-size:clamp(5rem,20vw,12rem);font-weight:300;color:var(--surface-2);line-height:1;margin-bottom:0;user-select:none;">404</p>
				<p class="eyebrow" style="margin-bottom:1.25rem; margin-top:-1rem;">Page Not Found</p>
				<div class="gold-line" style="margin:0 auto 1.5rem;"></div>
				<h1 class="display-md" style="max-width:480px; margin:0 auto 1.25rem;">
					This Frame is Empty
				</h1>
				<p class="body-lg" style="max-width:400px; margin:0 auto 2.5rem;">
					The page you're looking for doesn't exist - but there are plenty of great images waiting for you.
				</p>
				<div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap;">
					<a href="/" class="btn btn-primary btn-arrow">Back to Home</a>
					<a href="/portfolio.html" class="btn btn-outline">View Portfolio</a>
					<a href="https://niopictures.pixieset.com/booking/" target="_blank" rel="noopener noreferrer" class="btn btn-gold-outline">Book a Session</a>
				</div>

				<div style="margin-top:4rem; display:flex; gap:2rem; justify-content:center; flex-wrap:wrap;">
					<a href="/event-photography-katy-tx.html" style="font-family:var(--font-accent);font-size:0.62rem;letter-spacing:0.14em;text-transform:uppercase;color:var(--muted);transition:color var(--dur-fast);" onmouseover="this.style.color='var(--gold)'" onmouseout="this.style.color='var(--muted)'">Event Photography</a>
					<a href="/family-photography-katy-tx.html" style="font-family:var(--font-accent);font-size:0.62rem;letter-spacing:0.14em;text-transform:uppercase;color:var(--muted);transition:color var(--dur-fast);" onmouseover="this.style.color='var(--gold)'" onmouseout="this.style.color='var(--muted)'">Family Photography</a>
					<a href="/blog.html" style="font-family:var(--font-accent);font-size:0.62rem;letter-spacing:0.14em;text-transform:uppercase;color:var(--muted);transition:color var(--dur-fast);" onmouseover="this.style.color='var(--gold)'" onmouseout="this.style.color='var(--muted)'">Blog</a>
					<a href="/contact.html" style="font-family:var(--font-accent);font-size:0.62rem;letter-spacing:0.14em;text-transform:uppercase;color:var(--muted);transition:color var(--dur-fast);" onmouseover="this.style.color='var(--gold)'" onmouseout="this.style.color='var(--muted)'">Contact</a>
				</div>
			</div>
		</section>
	</main>
</BaseLayout>
