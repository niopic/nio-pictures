---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import aboutMain from "../assets/images/about/main.jpg";
const title = "About Palanivel | NiO Pictures Photographer — Katy TX";
const description = "Meet Palanivel, photographer at NiO Pictures in Katy TX. Events, Indian celebrations, and heirloom family portraits across Houston since 2017.";
const canonical = "https://niopictures.com/about.html";
const ogImage = "https://niopictures.com/assets/images/og-home.webp";
const extraHead = `<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        {"@type":"ListItem","position":1,"name":"Home","item":"https://niopictures.com/"},
        {"@type":"ListItem","position":2,"name":"About","item":"https://niopictures.com/about.html"}
    ]
  }
  <\/script>
<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Palanivel",
    "jobTitle": "Photographer",
    "description": "Event and family photographer based in Katy, Texas. Specializing in corporate events, Indian cultural celebrations, and heirloom family portraits since 2017.",
    "url": "https://niopictures.com/about.html",
    "image": "https://niopictures.com/assets/images/about-portrait.webp",
    "knowsAbout": [
      "Event Photography",
      "Family Photography",
      "Heirloom Portrait Photography",
      "Indian Cultural Event Photography",
      "South Asian Wedding Photography",
      "Corporate Event Photography",
      "Personal Branding Photography",
      "Candid Photography"
    ],
    "sameAs": [
      "https://www.instagram.com/nio_pictures",
      "https://www.facebook.com/profile.php?id=61580596898855"
    ],
    "worksFor": {"@id": "https://niopictures.com/#business"}
  }
  <\/script>`;
---

<BaseLayout title={title} description={description} canonical={canonical} ogImage={ogImage}>
  <Fragment slot="head" set:html={extraHead} />
<a href="#main-content" class="skip-link" style="position:absolute;top:-40px;left:1rem;background:var(--gold);color:var(--black);padding:0.5rem 1rem;border-radius:2px;font-family:var(--font-accent);font-size:0.7rem;letter-spacing:.1em;text-transform:uppercase;z-index:9999;transition:top var(--dur-fast);" onfocus="this.style.top='1rem'" onblur="this.style.top='-40px'">Skip to main content</a>

  <nav class="nav" role="navigation" aria-label="Main navigation">
    <a href="/" class="nav-logo">Ni<span>O</span> Pictures</a>
    <div class="nav-links">
      <a href="/event-photography-katy-tx.html">Events</a>
      <a href="/family-photography-katy-tx.html">Family</a>
      <a href="/blog.html">Blog</a>
      <a href="/portfolio.html">Portfolio</a>
      <a href="/about.html" class="active">About</a>
      <a href="/contact.html">Contact</a>
    </div>
    <a href="https://niopictures.pixieset.com/booking/" target="_blank" rel="noopener noreferrer" class="btn btn-primary nav-cta">Book Now</a>
    <button class="nav-toggle" aria-label="Open menu" aria-expanded="false"><span></span><span></span><span></span></button>
  </nav>

  <div class="nav-mobile" role="dialog" aria-label="Mobile navigation">
    <a href="/event-photography-katy-tx.html">Events</a>
    <a href="/family-photography-katy-tx.html">Family</a>
    <a href="/blog.html">Blog</a>
      <a href="/portfolio.html">Portfolio</a>
    <a href="/about.html">About</a>
    <a href="/contact.html">Contact</a>
    <a href="https://niopictures.pixieset.com/booking/" target="_blank" rel="noopener noreferrer" class="nav-mobile-cta">Book a Session →</a>
  </div>

  <!-- ── Header ─────────────────────────────────────────────── -->
  <div style="padding: calc(var(--section-pad) + 4rem) 0 var(--section-pad);">
    <div class="container">
      <div>
        <p class="eyebrow" style="margin-bottom: 1rem;">The Photographer</p>
        <div class="gold-line gold-line-animate"></div>
        <h1 class="display-xl">Our Story</h1>
      </div>
    </div>
  </div>

  <!-- ── Main About ──────────────────────────────────────────── -->
  <section class="section" style="padding-top: 0;">
    <div class="container">
      <div class="about-split">

        <div class="about-image-wrap reveal">
          <Image src={aboutMain} alt="Palanivel, event and family photographer at NiO Pictures, posing in Katy Texas photography studio" loading="lazy" style="background: var(--surface);" width={560} height={700} />
        </div>

        <div class="reveal reveal-delay-2">
          <p class="eyebrow" style="margin-bottom: 1rem;">Based in Katy, Texas</p>
          <div class="gold-line gold-line-animate"></div>
          <h2 class="display-md" style="margin-bottom: 1.5rem;">
            Photography With<br><em style="font-style:italic; color:var(--gold);">Purpose &amp; Presence</em>
          </h2>
          <p class="body-lg" style="margin-bottom: 1.25rem;">
            Palanivel is an event and portrait photographer based in Katy, Texas — and a software engineer who found his truest calling behind a camera.
          </p>
          <p class="body-lg" style="margin-bottom: 1.25rem;">
            As a family man with two children, he understands what's at stake when you ask someone to photograph your people and your moments. That understanding shapes everything about how he works — unhurried, observant, and always focused on what's real over what's posed.
          </p>
          <p class="body-lg" style="margin-bottom: 2.5rem;">
            Palanivel has a particular love for the energy of cultural celebrations, including South Asian and Indian events — the joyous chaos, the layered details, the moments of deep emotion that unfold in the in-between. He brings that same attentiveness to every family portrait and private event, regardless of background. Available for weekend and weeknight sessions throughout Katy, Houston, Sugar Land, and Richmond, TX.
          </p>

          <div class="stats-row" style="margin-bottom: 2.5rem; padding-bottom: 2.5rem; border-bottom: 1px solid var(--border-light);">
            <div class="stat-item">
              <div class="stat-number">50+</div>
              <div class="stat-label">Sessions</div>
            </div>
            <div class="stat-item">
              <div class="stat-number">Since 2017</div>
              <div class="stat-label">Experience</div>
            </div>
            <div class="stat-item">
              <div class="stat-number">4</div>
              <div class="stat-label">Cities</div>
            </div>
          </div>

          <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
            <a href="https://niopictures.pixieset.com/booking/" target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-arrow">Book a Portrait Session</a>
            <a href="/portfolio.html" class="btn btn-outline">See Photography Portfolio</a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── Values ─────────────────────────────────────────────── -->
  <section class="section" style="background: var(--surface); border-top: 1px solid var(--border-light);">
    <div class="container">
      <div class="section-header center reveal">
        <p class="eyebrow">The Approach</p>
        <div class="gold-line center gold-line-animate"></div>
        <h2 class="display-md">What We Believe In</h2>
        <p class="body-lg" style="max-width:680px; margin: 1.5rem auto 0;">
          Photography is not about taking pictures — it's about preserving moments. My goal is never to orchestrate — it's to document. The result is a collection of timeless, heartfelt images that will make you feel something for years to come.
        </p>
      </div>

      <div class="features-grid reveal reveal-delay-1">
        <div class="feature-card">
          <div class="feature-icon">◈</div>
          <h3 class="feature-title">Cinematic Vision</h3>
          <p class="body-sm">Every session is composed like a film. Lighting, timing, and emotion — all working together to create images that feel epic and intimate at once.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">◇</div>
          <h3 class="feature-title">Authentic Moments</h3>
          <p class="body-sm">We don't manufacture emotion. We find it. Our approach is quiet, observant, and always ready for the unscripted beat that defines the whole story.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">◉</div>
          <h3 class="feature-title">Legacy Craftsmanship</h3>
          <p class="body-sm">Images should be made to last. Every photograph is edited with archival care and delivered at the resolution you need for large prints, heirloom albums, and walls.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Service Areas ──────────────────────────────────────── -->
  <section class="section">
    <div class="container">
      <div class="section-header center reveal">
        <p class="eyebrow">Where We Work</p>
        <div class="gold-line center gold-line-animate"></div>
        <h2 class="display-md">Serving Greater Houston</h2>
      </div>

      <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: var(--border-light); max-width: 800px; margin: 0 auto;" class="reveal reveal-delay-1">
        <div style="background: var(--black); padding: 2.5rem; text-align: center;">
          <p class="eyebrow" style="color:var(--gold); margin-bottom:0.5rem;">Primary</p>
          <p class="display-md" style="font-size:1.4rem;">Katy, TX</p>
        </div>
        <div style="background: var(--black); padding: 2.5rem; text-align: center;">
          <p class="eyebrow" style="margin-bottom:0.5rem;">Also</p>
          <p class="display-md" style="font-size:1.4rem;">Houston</p>
        </div>
        <div style="background: var(--black); padding: 2.5rem; text-align: center;">
          <p class="eyebrow" style="margin-bottom:0.5rem;">Also</p>
          <p class="display-md" style="font-size:1.4rem;">Sugar Land</p>
        </div>
        <div style="background: var(--black); padding: 2.5rem; text-align: center;">
          <p class="eyebrow" style="margin-bottom:0.5rem;">Also</p>
          <p class="display-md" style="font-size:1.4rem;">Richmond</p>
        </div>
      </div>

      <p class="body-lg reveal" style="text-align:center; margin-top: 2rem;">
        Available for travel sessions and destination events. <a href="/contact.html" style="color:var(--gold);">Inquire here →</a>
      </p>
    </div>
  </section>

  <!-- ── CTA ────────────────────────────────────────────────── -->
  <section class="cta-banner reveal">
    <div class="container">
      <p class="eyebrow" style="margin-bottom:1.25rem;">Work Together</p>
      <h2 class="display-md" style="margin-bottom:1rem; max-width:480px; margin-left:auto; margin-right:auto;">
        Ready to Create<br><em style="font-style:italic; color:var(--gold);">Something Lasting?</em>
      </h2>
      <p class="body-lg" style="max-width:380px; margin:0 auto 2.5rem;">We'd love to hear about your upcoming event or session.</p>
      <div style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap;">
        <a href="https://niopictures.pixieset.com/booking/" target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-arrow">Book a Portrait Session</a>
        <a href="/contact.html" class="btn btn-outline">Get in Touch</a>
      </div>
    </div>
  </section>

  
</BaseLayout>
