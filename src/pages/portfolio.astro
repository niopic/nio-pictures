---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import eventsHero from "../assets/images/portfolio/portfolio-hero-1.jpg";
import familyHero from "../assets/images/portfolio/portfolio-hero-2.jpg";
import eventsPanel from "../assets/images/portfolio/portfolio-panel-1.jpg";
import familyPanel from "../assets/images/portfolio/portfolio-panel-2.jpg";

const title =
  "Portfolio | Event & Family Photography Gallery | NiO Pictures Katy TX";
const description =
  "Browse NiO Pictures' photography portfolio. Cinematic events and heirloom family portraits from Katy, Houston, Sugar Land & Richmond TX.";
const canonical = "https://niopictures.com/portfolio.html";
const ogImage = "https://niopictures.com/assets/images/og-home.webp";
const extraHead = `<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        {"@type":"ListItem","position":1,"name":"Home","item":"https://niopictures.com/"},
        {"@type":"ListItem","position":2,"name":"Portfolio","item":"https://niopictures.com/portfolio.html"}
    ]
  }
  <\/script>
<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "ImageGallery",
    "name": "Event & Family Photography Portfolio | NiO Pictures",
    "description": "Curated selection of cinematic event photography and heirloom family portraits from Katy, Houston, Sugar Land, and Richmond TX by photographer Palanivel.",
    "url": "https://niopictures.com/portfolio.html",
    "associatedMedia": [
      {
        "@type": "ImageObject",
        "name": "Cinematic event photography at Katy Texas celebration",
        "contentUrl": "https://niopictures.com/assets/images/events-hero.webp",
        "description": "Cinematic event photography showing guests and atmosphere during a celebration in Katy Texas",
        "creator": {"@type": "Person", "name": "Palanivel"},
        "creditText": "NiO Pictures",
        "license": "https://niopictures.com/terms.html",
        "acquireLicensePage": "https://niopictures.com/contact.html"
      },
      {
        "@type": "ImageObject",
        "name": "Outdoor family portrait in warm evening light near Katy Texas",
        "contentUrl": "https://niopictures.com/assets/images/family-hero.webp",
        "description": "Outdoor family portrait photographed in warm evening light near Katy Texas",
        "creator": {"@type": "Person", "name": "Palanivel"},
        "creditText": "NiO Pictures",
        "license": "https://niopictures.com/terms.html",
        "acquireLicensePage": "https://niopictures.com/contact.html"
      },
      {
        "@type": "ImageObject",
        "name": "Lifestyle family photography with cinematic light in Katy TX",
        "contentUrl": "https://niopictures.com/assets/images/family-panel.webp",
        "description": "Lifestyle family photography with movement and cinematic light in Katy TX",
        "creator": {"@type": "Person", "name": "Palanivel"},
        "creditText": "NiO Pictures",
        "license": "https://niopictures.com/terms.html",
        "acquireLicensePage": "https://niopictures.com/contact.html"
      },
      {
        "@type": "ImageObject",
        "name": "Candid corporate event photography coverage in Houston",
        "contentUrl": "https://niopictures.com/assets/images/events-panel.webp",
        "description": "Candid guest interaction during corporate event photography coverage in Houston",
        "creator": {"@type": "Person", "name": "Palanivel"},
        "creditText": "NiO Pictures",
        "license": "https://niopictures.com/terms.html",
        "acquireLicensePage": "https://niopictures.com/contact.html"
      }
    ],
    "author": {"@type": "Person", "name": "Palanivel", "url": "https://niopictures.com/about.html"},
    "copyrightHolder": {"@id": "https://niopictures.com/#business"}
  }
  <\/script>`;
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  ogImage={ogImage}
>
  <Fragment slot="head" set:html={extraHead} />
  <a
    href="#main-content"
    class="skip-link"
    style="position:absolute;top:-40px;left:1rem;background:var(--gold);color:var(--black);padding:0.5rem 1rem;border-radius:2px;font-family:var(--font-accent);font-size:0.7rem;letter-spacing:.1em;text-transform:uppercase;z-index:9999;transition:top var(--dur-fast);"
    onfocus="this.style.top='1rem'"
    onblur="this.style.top='-40px'">Skip to main content</a
  >

  <nav class="nav" role="navigation" aria-label="Main navigation">
    <a href="/" class="nav-logo">Ni<span>O</span> Pictures</a>
    <div class="nav-links">
      <a href="/event-photography-katy-tx.html">Events</a>
      <a href="/family-photography-katy-tx.html">Family</a>
      <a href="/portfolio.html" class="active">Portfolio</a>
      <a href="/about.html">About</a>
      <a href="/blog.html">Blog</a>
      <a href="/contact.html">Contact</a>
    </div>
    <a
      href="https://niopictures.pixieset.com/booking/"
      target="_blank"
      rel="noopener noreferrer"
      class="btn btn-primary nav-cta">Book Now</a
    >
    <button class="nav-toggle" aria-label="Open menu" aria-expanded="false"
      ><span></span><span></span><span></span></button
    >
  </nav>

  <div class="nav-mobile" role="dialog" aria-label="Mobile navigation">
    <a href="/event-photography-katy-tx.html">Events</a>
    <a href="/family-photography-katy-tx.html">Family</a>
    <a href="/portfolio.html">Portfolio</a>
    <a href="/about.html">About</a>
    <a href="/blog.html">Blog</a>
    <a href="/contact.html">Contact</a>
    <a
      href="https://niopictures.pixieset.com/booking/"
      target="_blank"
      rel="noopener noreferrer"
      class="nav-mobile-cta">Book a Session →</a
    >
  </div>

  <main id="main-content">
    <!-- Page Header -->
    <section class="port-header">
      <div class="container">
        <div class="reveal">
          <p class="eyebrow" style="margin-bottom:1rem;">
            Katy TX · Houston · Sugar Land · Richmond TX
          </p>
          <div class="gold-line gold-line-animate"></div>
          <h1 class="display-xl port-header-title">
            A Few Frames<br />
            <em style="font-style:italic; color:var(--gold);">Worth Keeping</em>
          </h1>
          <p class="body-lg port-header-intro">
            A small, intentional selection — event photography and family
            portraits from Katy, Houston, Sugar Land, and Richmond.
          </p>
        </div>
      </div>
    </section>

    <!-- Image 1: Events Hero + A Small Note -->
    <!-- First image gets the side-by-side editorial treatment -->
    <section class="port-lead-section">
      <div class="port-lead-grid">
        <!-- Image fills left on desktop, full width on mobile -->
        <figure class="port-lead-image reveal">
          <Image
            src={eventsHero}
            alt="Cinematic event photography — guests and atmosphere at a celebration in Katy Texas"
            loading="eager"
            fetchpriority="high"
            widths={[480, 800, 1200]}
            sizes="(max-width: 768px) 100vw, 55vw"
            quality={90}
            class="port-image-fill"
          />
        </figure>

        <!-- Philosophy note — right on desktop, below image on mobile -->
        <aside class="port-note reveal">
          <p class="port-kicker">A Small Note</p>
          <h2 class="display-md port-note-title">
            Enough to feel<br />the work.
          </h2>
          <p class="port-note-copy">
            I would rather show a few photographs with real weight to them than
            fill a page to make it look busy. What you see here is a small
            selection. The full gallery is at Pixieset.
          </p>
          <div class="port-note-links">
            <a
              href="https://niopictures.pixieset.com/"
              target="_blank"
              rel="noopener noreferrer"
              class="port-text-link"
            >
              Full Gallery →
            </a>
            <a href="/event-photography-katy-tx.html" class="port-text-link">
              Event Photography →
            </a>
          </div>
        </aside>
      </div>

      <!-- Caption below the lead image -->
      <div class="container">
        <div class="port-caption reveal">
          <p class="port-label">Event Coverage</p>
          <p class="port-caption-text">
            The energy in the room — and the quiet moments no one planned.
          </p>
          <a href="/event-photography-katy-tx.html" class="port-text-link">
            See Event Work →
          </a>
        </div>
      </div>
    </section>

    <!-- Image 2: Family Hero -->
    <section class="port-frame-section reveal">
      <figure class="port-figure">
        <div class="port-frame">
          <Image
            src={familyHero}
            alt="Outdoor family portrait in warm golden evening light near Katy Texas"
            loading="lazy"
            widths={[480, 900, 1600]}
            sizes="100vw"
            quality={90}
            class="port-image-fill"
          />
        </div>
        <figcaption>
          <div class="container">
            <div class="port-caption reveal">
              <p class="port-label">Family Portraits</p>
              <p class="port-caption-text">
                The quieter frames usually end up meaning the most later.
              </p>
              <a href="/family-photography-katy-tx.html" class="port-text-link">
                See Family Work →
              </a>
            </div>
          </div>
        </figcaption>
      </figure>
    </section>

    <!-- Image 3: Events Panel -->
    <section class="port-frame-section reveal">
      <figure class="port-figure">
        <div class="port-frame">
          <Image
            src={eventsPanel}
            alt="Candid guest interaction during corporate event photography coverage in Houston TX"
            loading="lazy"
            widths={[480, 900, 1600]}
            sizes="100vw"
            quality={90}
            class="port-image-fill"
          />
        </div>
        <figcaption>
          <div class="container">
            <div class="port-caption reveal">
              <p class="port-label">Corporate Events · Katy TX</p>
              <p class="port-caption-text">
                The polished frames matter — and so do the in-between ones.
              </p>
              <a href="/event-photography-katy-tx.html" class="port-text-link">
                Event Photography →
              </a>
            </div>
          </div>
        </figcaption>
      </figure>
    </section>

    <!-- Image 4: Family Panel -->
    <section class="port-frame-section reveal">
      <figure class="port-figure">
        <div class="port-frame">
          <Image
            src={familyPanel}
            alt="Lifestyle family photography with warmth and cinematic light in Katy TX"
            loading="lazy"
            widths={[480, 900, 1600]}
            sizes="100vw"
            quality={90}
            class="port-image-fill"
          />
        </div>
        <figcaption>
          <div class="container">
            <div class="port-caption reveal">
              <p class="port-label">Family Sessions · Houston Area</p>
              <p class="port-caption-text">
                For families who want warmth, motion, and something that still
                feels like them.
              </p>
              <a href="/family-photography-katy-tx.html" class="port-text-link">
                Family Photography →
              </a>
            </div>
          </div>
        </figcaption>
      </figure>
    </section>

    <!-- CTA -->
    <section class="port-cta reveal">
      <div class="container">
        <div class="port-cta-inner">
          <div>
            <p class="eyebrow" style="margin-bottom:0.75rem;">
              If This Feels Like Your Kind of Work
            </p>
            <h2 class="display-md port-cta-title">The next step is simple.</h2>
          </div>
          <div class="port-cta-actions">
            <a
              href="https://niopictures.pixieset.com/"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-outline">Full Gallery</a
            >
            <a
              href="https://niopictures.pixieset.com/booking/"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-primary btn-arrow">Book a Session</a
            >
          </div>
          <div class="port-cta-links">
            <a href="/event-photography-katy-tx.html" class="port-text-link"
              >Event Photography →</a
            >
            <a href="/family-photography-katy-tx.html" class="port-text-link"
              >Family Sessions →</a
            >
            <a href="/contact.html" class="port-text-link"
              >Ask About Your Date →</a
            >
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
