---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import aboutMain from "../assets/images/about/main.jpg";
import eventsHero from "../assets/images/heroes/events.jpg";
import eventsPanel from "../assets/images/panels/events.jpg";
import familyHero from "../assets/images/heroes/family.jpg";
import familyPanel from "../assets/images/panels/family.jpg";
const title = "Portfolio | Event \u0026 Family Photography Gallery | NiO Pictures Katy TX";
const description = "Browse NiO Pictures\u0027 photography portfolio. Cinematic events and heirloom family portraits from Katy, Houston, Sugar Land \u0026 Richmond TX.";
const canonical = "https://niopictures.com/portfolio.html";
const ogImage = "https://niopictures.com/assets/images/og-home.webp";
const extraHead = `<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        {"@type":"ListItem","position":1,"name":"Home","item":"https://niopictures.com/"},
        {"@type":"ListItem","position":2,"name":"Portfolio","item":"https://niopictures.com/portfolio.html"}
    ]
  }
  <\/script>
<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "ImageGallery",
    "name": "NiO Pictures Photography Portfolio",
    "description": "Curated selection of cinematic event photography and heirloom family portraits from Katy, Houston, Sugar Land, and Richmond TX by photographer Palanivel.",
    "url": "https://niopictures.com/portfolio.html",
    "author": {"@type": "Person", "name": "Palanivel", "url": "https://niopictures.com/about.html"},
    "copyrightHolder": {"@id": "https://niopictures.com/#business"},
    "associatedMedia": [
      {
        "@type": "ImageObject",
        "name": "Cinematic event photography at Katy Texas celebration",
        "contentUrl": "https://niopictures.com/assets/images/events-hero.webp",
        "description": "Cinematic event photography showing guests and atmosphere during a celebration in Katy Texas",
        "creator": {"@type": "Person", "name": "Palanivel"},
        "creditText": "NiO Pictures",
        "license": "https://niopictures.com/terms.html",
        "acquireLicensePage": "https://niopictures.com/contact.html"
      },
      {
        "@type": "ImageObject",
        "name": "Outdoor family portrait in warm evening light near Katy Texas",
        "contentUrl": "https://niopictures.com/assets/images/family-hero.webp",
        "description": "Outdoor family portrait photographed in warm evening light near Katy Texas",
        "creator": {"@type": "Person", "name": "Palanivel"},
        "creditText": "NiO Pictures",
        "license": "https://niopictures.com/terms.html",
        "acquireLicensePage": "https://niopictures.com/contact.html"
      },
      {
        "@type": "ImageObject",
        "name": "Lifestyle family photography with cinematic light in Katy TX",
        "contentUrl": "https://niopictures.com/assets/images/family-panel.webp",
        "description": "Lifestyle family photography with movement and cinematic light in Katy TX",
        "creator": {"@type": "Person", "name": "Palanivel"},
        "creditText": "NiO Pictures",
        "license": "https://niopictures.com/terms.html",
        "acquireLicensePage": "https://niopictures.com/contact.html"
      },
      {
        "@type": "ImageObject",
        "name": "Candid corporate event photography coverage in Houston",
        "contentUrl": "https://niopictures.com/assets/images/events-panel.webp",
        "description": "Candid guest interaction during corporate event photography coverage in Houston",
        "creator": {"@type": "Person", "name": "Palanivel"},
        "creditText": "NiO Pictures",
        "license": "https://niopictures.com/terms.html",
        "acquireLicensePage": "https://niopictures.com/contact.html"
      }
    ]
  }
  <\/script>`;
---

<BaseLayout title={title} description={description} canonical={canonical} ogImage={ogImage}>
  <Fragment slot="head" set:html={extraHead} />
<a href="#main-content" class="skip-link" style="position:absolute;top:-40px;left:1rem;background:var(--gold);color:var(--black);padding:0.5rem 1rem;border-radius:2px;font-family:var(--font-accent);font-size:0.7rem;letter-spacing:.1em;text-transform:uppercase;z-index:9999;transition:top var(--dur-fast);" onfocus="this.style.top='1rem'" onblur="this.style.top='-40px'">Skip to main content</a>

  <nav class="nav" role="navigation" aria-label="Main navigation">
    <a href="/" class="nav-logo">Ni<span>O</span> Pictures</a>
    <div class="nav-links">
      <a href="/event-photography-katy-tx.html">Events</a>
      <a href="/family-photography-katy-tx.html">Family</a>
      <a href="/portfolio.html" class="active">Portfolio</a>
      <a href="/about.html">About</a>
      <a href="/blog.html">Blog</a>
      <a href="/contact.html">Contact</a>
    </div>
    <a href="https://niopictures.pixieset.com/booking/" target="_blank" rel="noopener noreferrer" class="btn btn-primary nav-cta">Book Now</a>
    <button class="nav-toggle" aria-label="Open menu" aria-expanded="false"><span></span><span></span><span></span></button>
  </nav>

  <div class="nav-mobile" role="dialog" aria-label="Mobile navigation">
    <a href="/event-photography-katy-tx.html">Events</a>
    <a href="/family-photography-katy-tx.html">Family</a>
    <a href="/portfolio.html">Portfolio</a>
    <a href="/about.html">About</a>
    <a href="/blog.html">Blog</a>
    <a href="/contact.html">Contact</a>
    <a href="https://niopictures.pixieset.com/booking/" target="_blank" rel="noopener noreferrer" class="nav-mobile-cta">Book a Session →</a>
  </div>

  <main id="main-content">
    <section class="portfolio-gallery-hero-section">
      <div class="container portfolio-gallery-hero">
        <div class="portfolio-gallery-copy">
          <p class="eyebrow" style="margin-bottom: 1rem;">Selected Work</p>
          <div class="gold-line gold-line-animate"></div>
          <h1 class="display-xl portfolio-gallery-title">
            Event &amp; Family<br /><em style="font-style:italic; color:var(--gold);">Photography Portfolio</em>
          </h1>
          <p class="body-lg portfolio-gallery-intro">
            A quieter look at the work — a small selection of event photography and family portraits from Katy, Houston, Sugar Land, and Richmond. Kept intentionally light on words so the images can do most of the talking.
          </p>
        </div>

        <figure class="portfolio-gallery-lead">
          <div class="portfolio-gallery-frame portfolio-gallery-frame-lead">
            <Image src={eventsHero} alt="Cinematic event photography showing guests and atmosphere during a Katy Texas celebration" loading="eager" fetchpriority="high" width={1200} height={820} />
          </div>
        </figure>
      </div>
    </section>

    <section class="section" style="padding-top: 0;">
      <div class="container">
        <nav class="portfolio-gallery-service-nav reveal" aria-label="Portfolio pathways">
          <span class="portfolio-gallery-service-label">Start with</span>
          <a href="/event-photography-katy-tx.html">Event Photography</a>
          <a href="/family-photography-katy-tx.html">Family Sessions</a>
          <a href="/contact.html">Ask About Your Date</a>
          <a href="/book.html">Book a Session</a>
        </nav>
      </div>
    </section>

    <section class="section portfolio-gallery-wall-section" style="padding-top: 0;">
      <div class="container">
        <div class="portfolio-gallery-wall">
          <figure class="portfolio-gallery-piece portfolio-gallery-piece-portrait reveal">
            <div class="portfolio-gallery-frame portfolio-gallery-frame-portrait">
              <Image src={familyHero} alt="Outdoor family portrait photographed in warm evening light near Katy Texas" loading="lazy" width={820} height={1025} />
            </div>
            <figcaption class="portfolio-gallery-caption">
              <div>
                <p class="portfolio-gallery-label">Family Portraits</p>
                <p class="portfolio-gallery-caption-text">The quieter frames usually end up meaning the most later.</p>
              </div>
              <a href="/family-photography-katy-tx.html" class="portfolio-gallery-text-link">See Family Work</a>
            </figcaption>
          </figure>

          <aside class="portfolio-gallery-note reveal reveal-delay-1">
            <p class="portfolio-kicker">A Small Note</p>
            <h2 class="display-md portfolio-gallery-note-title">Enough to feel the work.</h2>
            <p class="portfolio-gallery-note-copy">
              I would rather show a few photographs with some weight to them than fill the page just to make it look busy.
            </p>
            <a href="/contact.html" class="portfolio-gallery-text-link">Ask About Your Session</a>
          </aside>

          <figure class="portfolio-gallery-piece portfolio-gallery-piece-detail reveal reveal-delay-2">
            <div class="portfolio-gallery-frame portfolio-gallery-frame-square">
              <Image src={aboutMain} alt="Portrait with warm editorial lighting and professional styling during milestone photography session in Katy TX studio with beautiful natural window light" loading="lazy" width={780} height={780} />
            </div>
            <figcaption class="portfolio-gallery-caption">
              <div>
                <p class="portfolio-gallery-label">Milestones</p>
                <p class="portfolio-gallery-caption-text">A little direction, a little room to breathe, and the moment still stays intact.</p>
              </div>
              <a href="/contact.html" class="portfolio-gallery-text-link">Start a Conversation</a>
            </figcaption>
          </figure>

          <figure class="portfolio-gallery-piece portfolio-gallery-piece-landscape reveal">
            <div class="portfolio-gallery-frame portfolio-gallery-frame-landscape">
              <Image src={familyPanel} alt="Lifestyle family photography with movement and cinematic light in Katy TX" loading="lazy" width={980} height={680} />
            </div>
            <figcaption class="portfolio-gallery-caption">
              <div>
                <p class="portfolio-gallery-label">Family Sessions</p>
                <p class="portfolio-gallery-caption-text">For families who want warmth, motion, and something that still feels like them.</p>
              </div>
              <a href="/book.html" class="portfolio-gallery-text-link">Book a Session</a>
            </figcaption>
          </figure>

          <figure class="portfolio-gallery-piece portfolio-gallery-piece-landscape reveal reveal-delay-1">
            <div class="portfolio-gallery-frame portfolio-gallery-frame-landscape">
              <Image src={eventsPanel} alt="Candid guest interaction during corporate event photography coverage in Houston" loading="lazy" width={980} height={680} />
            </div>
            <figcaption class="portfolio-gallery-caption">
              <div>
                <p class="portfolio-gallery-label">Event Coverage</p>
                <p class="portfolio-gallery-caption-text">The polished frames matter, but so do the in-between ones that make the room feel real.</p>
              </div>
              <a href="/event-photography-katy-tx.html" class="portfolio-gallery-text-link">See Event Work</a>
            </figcaption>
          </figure>
        </div>
      </div>
    </section>

    <section class="section" style="padding-top: 0;">
      <div class="container">
        <div class="portfolio-gallery-cta reveal">
          <div>
            <p class="portfolio-kicker">If This Feels Like Your Kind of Work</p>
            <h2 class="display-md portfolio-gallery-cta-title">The next step is simple.</h2>
          </div>
          <div>
            <p class="body-lg portfolio-gallery-cta-copy">
              Start with the page that fits your session, or open the full gallery if you want to keep looking a little longer.
            </p>
            <div class="portfolio-gallery-cta-links">
              <a href="/event-photography-katy-tx.html">Event Photography</a>
              <a href="/family-photography-katy-tx.html">Family Sessions</a>
              <a href="https://niopictures.pixieset.com/booking/" target="_blank" rel="noopener noreferrer">Book Now</a>
              <a href="https://niopictures.pixieset.com/" target="_blank" rel="noopener noreferrer">Full Gallery</a>
            </div>
          </div>
        </div>
      </div>
    </section>
</BaseLayout>
