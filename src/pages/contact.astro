---
import BaseLayout from "../layouts/BaseLayout.astro";
const title = "Contact NiO Pictures | Event \u0026 Family Photographer Katy TX";
const description = "Contact Palanivel at NiO Pictures. Photography inquiries in Katy TX. Call 281-409-3585 or email niopictureskaty@gmail.com. Serving Houston, Cypress, Sugar Land \u0026 Richmond.";
const canonical = "https://niopictures.com/contact.html";
const ogImage = "https://niopictures.com/assets/images/og-home.webp";
const extraHead = "\u003cscript type=\"application/ld+json\"\u003e\n  {\n    \"@context\": \"https://schema.org\",\n    \"@type\": \"BreadcrumbList\",\n    \"itemListElement\": [\n        {\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://niopictures.com/\"},\n        {\"@type\":\"ListItem\",\"position\":2,\"name\":\"Contact\",\"item\":\"https://niopictures.com/contact.html\"}\n    ]\n  }\n  \u003c/script\u003e";
---

<BaseLayout title={title} description={description} canonical={canonical} ogImage={ogImage}>
  <Fragment slot="head" set:html={extraHead} />
<a href="#main-content" class="skip-link" style="position:absolute;top:-40px;left:1rem;background:var(--gold);color:var(--black);padding:0.5rem 1rem;border-radius:2px;font-family:var(--font-accent);font-size:0.7rem;letter-spacing:.1em;text-transform:uppercase;z-index:9999;transition:top .2s;" onfocus="this.style.top='1rem'" onblur="this.style.top='-40px'">Skip to main content</a>

  <nav class="nav">
    <a href="/" class="nav-logo">Ni<span>O</span> Pictures</a>
    <div class="nav-links">
      <a href="/event-photography-katy-tx.html">Events</a>
      <a href="/family-photography-katy-tx.html">Family</a>
      <a href="/blog.html">Blog</a>
      <a href="/portfolio.html">Portfolio</a>
      <a href="/about.html">About</a>
      <a href="/contact.html" class="active">Contact</a>
    </div>
    <a href="https://niopictures.pixieset.com/booking/" target="_blank" rel="noopener noreferrer" class="btn btn-primary nav-cta">Book Now</a>
    <button class="nav-toggle" aria-label="Open menu"><span></span><span></span><span></span></button>
  </nav>

  <div class="nav-mobile">
    <a href="/event-photography-katy-tx.html">Events</a>
    <a href="/family-photography-katy-tx.html">Family</a>
    <a href="/blog.html">Blog</a>
      <a href="/portfolio.html">Portfolio</a>
    <a href="/about.html">About</a>
    <a href="/contact.html">Contact</a>
    <a href="https://niopictures.pixieset.com/booking/" target="_blank" rel="noopener noreferrer" style="color:var(--gold);margin-top:1rem;">Book a Session →</a>
  </div>

  <!-- ── Contact Section ────────────────────────────────────── -->
  <section style="min-height: 100svh; display: flex; align-items: center; padding: calc(var(--section-pad) + 4rem) 0 var(--section-pad);">
    <div class="container">
      <div style="display: grid; grid-template-columns: 1fr 1.4fr; gap: clamp(3rem, 8vw, 7rem); align-items: start;">

        <!-- Left: Info -->
        <div class="reveal">
          <p class="eyebrow" style="margin-bottom: 1rem;">Reach Out</p>
          <div class="gold-line gold-line-animate"></div>
          <h1 class="display-lg" style="margin-bottom: 1.5rem;">
            Let's Start a<br><em style="font-style:italic; color:var(--gold);">Conversation</em>
          </h1>
          <p class="body-lg" style="margin-bottom: 3rem;">
            Whether you have a question, want to discuss your vision, or are ready to book — we'd love to hear from you.
          </p>

          <!-- Info Blocks -->
          <div style="display: flex; flex-direction: column; gap: 2rem;">

            <div>
              <p class="footer-heading">Based In</p>
              <p class="body-lg" style="color: var(--cream);">Katy, Texas</p>
              <p class="body-sm" style="margin-top:0.2rem;">Serving Houston, Cypress, Sugar Land, and Richmond</p>
            </div>

            <div>
              <p class="footer-heading">Phone</p>
              <a href="tel:2814093585" style="color:var(--gold); font-size:0.95rem;">281-409-3585</a>
            </div>

            <div>
              <p class="footer-heading">Email</p>
              <a href="mailto:niopictureskaty@gmail.com" style="color:var(--gold); font-size:0.95rem;">niopictureskaty@gmail.com</a>
            </div>

            <div>
              <p class="footer-heading">Book a Session</p>
              <a href="https://niopictures.pixieset.com/booking/" target="_blank" rel="noopener noreferrer" style="color:var(--gold); font-size:0.95rem;">
                niopictures.pixieset.com/booking
              </a>
            </div>

            <div>
              <p class="footer-heading">View Gallery</p>
              <a href="https://niopictures.pixieset.com/" target="_blank" rel="noopener noreferrer" style="color:var(--gold); font-size:0.95rem;">
                niopictures.pixieset.com
              </a>
            </div>

            <div>
              <p class="footer-heading" style="margin-bottom:0.75rem;">Follow Along</p>
              <div style="display:flex; gap:0.75rem;">
                <a href="https://www.instagram.com/nio_pictures" target="_blank" rel="noopener noreferrer" aria-label="Instagram" style="display:flex;align-items:center;gap:0.5rem;font-family:var(--font-accent);font-size:0.65rem;letter-spacing:0.14em;text-transform:uppercase;color:var(--muted);padding:0.6rem 1rem;border:1px solid var(--border);border-radius:2px;transition:all var(--dur-fast) var(--ease);" onmouseover="this.style.borderColor='var(--gold)';this.style.color='var(--gold)'" onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--muted)'">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/></svg>
                  @nio_pictures
                </a>
                <a href="https://www.facebook.com/profile.php?id=61580596898855" target="_blank" rel="noopener noreferrer" aria-label="Facebook" style="display:flex;align-items:center;gap:0.5rem;font-family:var(--font-accent);font-size:0.65rem;letter-spacing:0.14em;text-transform:uppercase;color:var(--muted);padding:0.6rem 1rem;border:1px solid var(--border);border-radius:2px;transition:all var(--dur-fast) var(--ease);" onmouseover="this.style.borderColor='var(--gold)';this.style.color='var(--gold)'" onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--muted)'">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
                  Facebook
                </a>
              </div>
            </div>

            <div style="padding-top: 1.5rem; border-top: 1px solid var(--border-light);">
              <p class="footer-heading" style="margin-bottom: 1rem;">Quick Links</p>
              <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
                <a href="/event-photography-katy-tx.html" class="btn btn-outline" style="padding: 0.6rem 1.25rem; font-size:0.6rem;">Events</a>
                <a href="/family-photography-katy-tx.html" class="btn btn-outline" style="padding: 0.6rem 1.25rem; font-size:0.6rem;">Family</a>
                <a href="/portfolio.html" class="btn btn-outline" style="padding: 0.6rem 1.25rem; font-size:0.6rem;">Portfolio</a>
              </div>
            </div>

          </div>
        </div>

        <!-- Right: Form -->
        <div class="reveal reveal-delay-2">
          <div style="background: var(--surface); border: 1px solid var(--border-light); border-radius: 2px; padding: clamp(2rem, 4vw, 3rem);">
            <p style="font-family:var(--font-display); font-size:1.4rem; font-weight:300; color:var(--cream); margin-bottom:2rem;">Send a Message</p>

            <form id="contact-form" novalidate style="position:relative;">
              <!-- Honeypot spam protection — hidden from real users -->
              <div style="position:absolute;left:-9999px;top:-9999px;" aria-hidden="true">
                <label for="website">Leave this empty</label>
                <input type="text" id="website" name="website" tabindex="-1" autocomplete="off">
              </div>
              <div class="form-row">
                <div class="form-group">
                  <label class="form-label" for="contact-name">Full Name</label>
                  <input class="form-control" type="text" id="contact-name" name="name" placeholder="Your name" required autocomplete="name">
                </div>
                <div class="form-group">
                  <label class="form-label" for="contact-email">Email Address</label>
                  <input class="form-control" type="email" id="contact-email" name="email" placeholder="your@email.com" required autocomplete="email">
                </div>
              </div>

              <div class="form-group">
                <label class="form-label" for="contact-subject">Subject</label>
                <select class="form-control" id="contact-subject" name="subject">
                  <option value="" disabled selected>Select a topic</option>
                  <option value="event-inquiry">Event Photography Inquiry</option>
                  <option value="family-inquiry">Family Session Inquiry</option>
                  <option value="pricing">Pricing & Packages</option>
                  <option value="availability">Availability Check</option>
                  <option value="general">General Question</option>
                  <option value="other">Other</option>
                </select>
              </div>

              <div class="form-group">
                <label class="form-label" for="contact-message">Message</label>
                <textarea class="form-control" id="contact-message" name="message" placeholder="Tell us about your project, event, or questions…" required style="min-height:160px;"></textarea>
              </div>

              <button type="submit" class="btn btn-primary btn-arrow" style="width:100%; justify-content:center;">
                Send Message
              </button>

              <p class="body-sm" style="text-align:center; margin-top:1rem; font-size:0.8rem;">
                We typically respond within <span style="color:var(--gold);">24 hours</span>. For urgent bookings, use the direct booking link above.
              </p>
            </form>

          </div>

          <!-- Direct Booking CTA below form -->
          <div style="margin-top: 1.5rem; background: var(--surface-2); border: 1px solid var(--border); border-radius: 2px; padding: 1.5rem; display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap;">
            <div>
              <p style="font-size:0.85rem; color:var(--cream); font-weight:400; margin-bottom:0.2rem;">Ready to book now?</p>
              <p class="body-sm">Skip the form and reserve your date directly.</p>
            </div>
            <a href="https://niopictures.pixieset.com/booking/" target="_blank" rel="noopener noreferrer" class="btn btn-gold-outline btn-arrow" style="white-space:nowrap;">Book Now</a>
          </div>
        </div>

      </div>
    </div>
  </section>

  
</BaseLayout>
