---
import BaseLayout from "../layouts/BaseLayout.astro";
const title = "Contact NiO Pictures | Event \u0026 Family Photographer Katy TX";
const description =
  "Contact Palanivel at NiO Pictures — event & family photographer in Katy TX. Call 281-409-3585. Serving Houston, Cypress, Sugar Land & Richmond.";
const canonical = "https://niopictures.com/contact.html";
const ogImage = "https://niopictures.com/assets/images/og-home.webp";
const extraHead = `<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        {"@type":"ListItem","position":1,"name":"Home","item":"https://niopictures.com/"},
        {"@type":"ListItem","position":2,"name":"Contact","item":"https://niopictures.com/contact.html"}
    ]
  }
  <\/script>
<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Photography Inquiry & Booking — NiO Pictures",
    "serviceType": "Photography Booking",
    "provider": {"@id": "https://niopictures.com/#business"},
    "areaServed": [
      {"@type": "City", "name": "Katy"},
      {"@type": "City", "name": "Houston"},
      {"@type": "City", "name": "Sugar Land"},
      {"@type": "City", "name": "Richmond"},
      {"@type": "City", "name": "Cypress"}
    ],
    "url": "https://niopictures.com/contact.html",
    "contactPoint": {
      "@type": "ContactPoint",
      "telephone": "+12814093585",
      "email": "niopictureskaty@gmail.com",
      "contactType": "customer service",
      "availableLanguage": "English"
    }
  }
  <\/script>`;
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  ogImage={ogImage}
>
  <Fragment slot="head" set:html={extraHead} />
  <a
    href="#main-content"
    class="skip-link"
    style="position:absolute;top:-40px;left:1rem;background:var(--gold);color:var(--black);padding:0.5rem 1rem;border-radius:2px;font-family:var(--font-accent);font-size:0.7rem;letter-spacing:.1em;text-transform:uppercase;z-index:9999;transition:top var(--dur-fast);"
    onfocus="this.style.top='1rem'"
    onblur="this.style.top='-40px'">Skip to main content</a
  >

  <nav class="nav" role="navigation" aria-label="Main navigation">
    <a href="/" class="nav-logo">Ni<span>O</span> Pictures</a>
    <div class="nav-links">
      <a href="/event-photography-katy-tx.html">Events</a>
      <a href="/family-photography-katy-tx.html">Family</a>
      <a href="/portfolio.html">Portfolio</a>
      <a href="/about.html">About</a>
      <a href="/blog.html">Blog</a>
      <a href="/contact.html" class="active">Contact</a>
    </div>
    <a
      href="https://niopictures.pixieset.com/booking/"
      target="_blank"
      rel="noopener noreferrer"
      class="btn btn-primary nav-cta">Book Now</a
    >
    <button class="nav-toggle" aria-label="Open menu" aria-expanded="false"
      ><span></span><span></span><span></span></button
    >
  </nav>

  <div class="nav-mobile" role="dialog" aria-label="Mobile navigation">
    <a href="/event-photography-katy-tx.html">Events</a>
    <a href="/family-photography-katy-tx.html">Family</a>
    <a href="/portfolio.html">Portfolio</a>
    <a href="/about.html">About</a>
    <a href="/blog.html">Blog</a>
    <a href="/contact.html">Contact</a>
    <a
      href="https://niopictures.pixieset.com/booking/"
      target="_blank"
      rel="noopener noreferrer"
      class="nav-mobile-cta">Book a Session →</a
    >
  </div>

  <!-- ── Contact Section ────────────────────────────────────── -->
  <section
    style="min-height: 100svh; display: flex; align-items: center; padding: calc(var(--section-pad) + 4rem) 0 var(--section-pad);"
  >
    <div class="container">
      <div
        class="contact-layout-grid"
        style="display: grid; grid-template-columns: 1fr 1.4fr; gap: clamp(3rem, 8vw, 7rem); align-items: start;"
      >
        <!-- Left: Info -->
        <div>
          <p class="eyebrow" style="margin-bottom: 1rem;">Reach Out</p>
          <div class="gold-line gold-line-animate"></div>
          <h1 class="display-xl" style="margin-bottom: 1.5rem;">
            Let's Start a<br /><em style="font-style:italic; color:var(--gold);"
              >Conversation</em
            >
          </h1>
          <p class="body-lg" style="margin-bottom: 3rem;">
            Whether you have a question, want to discuss your vision, or are
            ready to book — we'd love to hear from you.
          </p>

          <!-- Info Blocks -->
          <div style="display: flex; flex-direction: column; gap: 2rem;">
            <div>
              <p class="footer-heading">Based In</p>
              <p class="body-lg" style="color: var(--cream);">Katy, Texas</p>
              <p class="body-sm" style="margin-top:0.2rem;">
                Serving Houston, Cypress, Sugar Land, and Richmond
              </p>
            </div>

            <div>
              <p class="footer-heading">Phone</p>
              <a
                href="tel:+12814093585"
                style="color:var(--gold); font-size:0.95rem;">281-409-3585</a
              >
            </div>

            <div>
              <p class="footer-heading">Email</p>
              <a
                href="mailto:niopictureskaty@gmail.com"
                style="color:var(--gold); font-size:0.95rem;"
                >niopictureskaty@gmail.com</a
              >
            </div>

            <div>
              <p class="footer-heading">Book a Session</p>
              <a
                href="https://niopictures.pixieset.com/booking/"
                target="_blank"
                rel="noopener noreferrer"
                style="color:var(--gold); font-size:0.95rem;"
              >
                niopictures.pixieset.com/booking
              </a>
            </div>

            <div>
              <p class="footer-heading">View Gallery</p>
              <a
                href="https://niopictures.pixieset.com/"
                target="_blank"
                rel="noopener noreferrer"
                style="color:var(--gold); font-size:0.95rem;"
              >
                niopictures.pixieset.com
              </a>
            </div>

            <div>
              <p class="footer-heading" style="margin-bottom:0.75rem;">
                Follow Along
              </p>
              <div style="display:flex; gap:0.75rem;">
                <a
                  href="https://www.instagram.com/nio_pictures"
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="Instagram"
                  class="social-chip"
                >
                  <svg
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><rect x="2" y="2" width="20" height="20" rx="5"
                    ></rect><circle cx="12" cy="12" r="4"></circle><circle
                      cx="17.5"
                      cy="6.5"
                      r="0.5"
                      fill="currentColor"></circle></svg
                  >
                  @nio_pictures
                </a>
                <a
                  href="https://www.facebook.com/profile.php?id=61580596898855"
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="Facebook"
                  class="social-chip"
                >
                  <svg
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path
                      d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"
                    ></path></svg
                  >
                  Facebook
                </a>
              </div>
            </div>

            <div
              style="padding-top: 1.5rem; border-top: 1px solid var(--border-light);"
            >
              <p class="footer-heading" style="margin-bottom: 1rem;">
                Quick Links
              </p>
              <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
                <a
                  href="/event-photography-katy-tx.html"
                  class="btn btn-outline btn-sm">Events</a
                >
                <a
                  href="/family-photography-katy-tx.html"
                  class="btn btn-outline btn-sm">Family</a
                >
                <a href="/portfolio.html" class="btn btn-outline btn-sm"
                  >Portfolio</a
                >
              </div>
            </div>
          </div>
        </div>

        <!-- Right: Form -->
        <div class="reveal reveal-delay-2">
          <div
            style="background: var(--surface); border: 1px solid var(--border-light); border-radius: 2px; padding: clamp(2rem, 4vw, 3rem);"
          >
            <p
              style="font-family:var(--font-display); font-size:1.4rem; font-weight:300; color:var(--cream); margin-bottom:2rem;"
            >
              Send a Message
            </p>

            <form id="contact-form" novalidate style="position:relative;">
              <!-- Honeypot spam protection — hidden from real users -->
              <div
                style="position:absolute;left:-9999px;top:-9999px;"
                aria-hidden="true"
              >
                <label for="contact-website">Leave this empty</label>
                <input
                  type="text"
                  id="contact-website"
                  name="website"
                  tabindex="-1"
                  autocomplete="off"
                />
              </div>
              <div class="form-row">
                <div class="form-group">
                  <label class="form-label" for="contact-name">Full Name</label>
                  <input
                    class="form-control"
                    type="text"
                    id="contact-name"
                    name="name"
                    placeholder="Your name"
                    required
                    autocomplete="name"
                  />
                </div>
                <div class="form-group">
                  <label class="form-label" for="contact-email"
                    >Email Address</label
                  >
                  <input
                    class="form-control"
                    type="email"
                    id="contact-email"
                    name="email"
                    placeholder="your@email.com"
                    required
                    autocomplete="email"
                  />
                </div>
              </div>

              <div class="form-group">
                <label class="form-label" for="contact-subject">Subject</label>
                <select
                  class="form-control"
                  id="contact-subject"
                  name="subject"
                >
                  <option value="" disabled selected>Select a topic</option>
                  <option value="event-inquiry"
                    >Event Photography Inquiry</option
                  >
                  <option value="family-inquiry">Family Session Inquiry</option>
                  <option value="pricing">Pricing & Packages</option>
                  <option value="availability">Availability Check</option>
                  <option value="general">General Question</option>
                  <option value="other">Other</option>
                </select>
              </div>

              <div class="form-group">
                <label class="form-label" for="contact-message">Message</label>
                <textarea
                  class="form-control"
                  id="contact-message"
                  name="message"
                  placeholder="Tell us about your project, event, or questions…"
                  required
                  style="min-height:160px;"></textarea>
              </div>

              <button type="submit" class="btn btn-primary btn-arrow btn-block">
                Send Message
              </button>

              <p
                class="body-sm"
                style="text-align:center; margin-top:1rem; font-size:0.8rem;"
              >
                We typically respond within <span style="color:var(--gold);"
                  >24 hours</span
                >. For urgent bookings, use the direct booking link above.
              </p>
            </form>
          </div>

          <!-- Direct Booking CTA below form -->
          <div
            style="margin-top: 1.5rem; background: var(--surface-2); border: 1px solid var(--border); border-radius: 2px; padding: 1.5rem; display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap;"
          >
            <div>
              <p
                style="font-size:0.85rem; color:var(--cream); font-weight:400; margin-bottom:0.2rem;"
              >
                Ready to book now?
              </p>
              <p class="body-sm">
                Skip the form and reserve your date directly.
              </p>
            </div>
            <a
              href="https://niopictures.pixieset.com/booking/"
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-gold-outline btn-arrow btn-nowrap">Book Now</a
            >
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── How to Reach Us ──────────────────────────────────────────── -->
  <section
    class="section"
    style="background: var(--surface); border-top: 1px solid var(--border-light); margin-top: 4rem;"
  >
    <div class="container">
      <div class="section-header center reveal">
        <p class="eyebrow">Process & Support</p>
        <div class="gold-line center gold-line-animate"></div>
        <h2 class="display-md">How to Reach NiO Pictures</h2>
      </div>

      <div
        style="display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; max-width: 960px; margin: 0 auto;"
        class="reveal reveal-delay-1"
      >
        <div>
          <h3
            style="font-family: var(--font-display); font-size: 1.2rem; color: var(--gold); margin-bottom: 1.5rem;"
          >
            Response Time & Availability
          </h3>
          <p class="body-lg" style="margin-bottom: 1.5rem;">
            We typically respond to inquiries within <span
              style="color: var(--gold);">24 hours</span
            >. Calls and texts often get faster replies, especially for urgent
            bookings. Our serving hours are flexible — we're available evenings
            and weekends across Katy TX, Houston, Sugar Land, and Richmond to
            accommodate your schedule.
          </p>
          <p class="body-lg" style="margin-bottom: 1.5rem;">
            For <span style="color: var(--gold);">immediate booking</span>, use
            our online calendar link. For questions about rates, package
            options, or custom requests, email or call — we love talking through
            your vision before you commit.
          </p>
        </div>

        <div>
          <h3
            style="font-family: var(--font-display); font-size: 1.2rem; color: var(--gold); margin-bottom: 1.5rem;"
          >
            The Booking Process
          </h3>
          <ol style="margin-left: 1.5rem; margin-bottom: 1.5rem;">
            <li style="margin-bottom: 1rem; color: var(--muted);">
              <span style="color: var(--cream);">Reach out</span> — Call, text, email,
              or submit the form. Tell us about your event or session idea.
            </li>
            <li style="margin-bottom: 1rem; color: var(--muted);">
              <span style="color: var(--cream);">Consultation</span> — We discuss
              details, answer questions, and confirm availability. No pressure.
            </li>
            <li style="margin-bottom: 1rem; color: var(--muted);">
              <span style="color: var(--cream);">Agreement</span> — Once you're ready,
              we secure your date with a deposit and contract.
            </li>
            <li style="color: var(--muted);">
              <span style="color: var(--cream);">Delivery</span> — Post-session, you'll
              receive edited galleries within 2–3 weeks.
            </li>
          </ol>
        </div>
      </div>

      <div
        style="background: var(--black); border: 1px solid var(--border-light); border-radius: 2px; padding: 2.5rem; margin-top: 3rem;"
        class="reveal reveal-delay-2"
      >
        <h3
          style="font-family: var(--font-display); font-size: 1.2rem; color: var(--cream); margin-bottom: 1.5rem;"
        >
          Frequently Asked Questions
        </h3>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
          <div>
            <p
              style="color: var(--gold); font-weight: 500; margin-bottom: 0.5rem;"
            >
              When will you respond to my inquiry?
            </p>
            <p class="body-sm" style="color: var(--muted);">
              Usually within 24 hours via email. Calls and texts often get
              faster replies. Check your spam folder if emailing.
            </p>
          </div>

          <div>
            <p
              style="color: var(--gold); font-weight: 500; margin-bottom: 0.5rem;"
            >
              Do you travel outside Katy?
            </p>
            <p class="body-sm" style="color: var(--muted);">
              Yes! We regularly shoot in Houston, Sugar Land, Richmond, and
              beyond. Travel fees apply for sessions far from Katy TX.
            </p>
          </div>

          <div>
            <p
              style="color: var(--gold); font-weight: 500; margin-bottom: 0.5rem;"
            >
              What if I need same-week availability?
            </p>
            <p class="body-sm" style="color: var(--muted);">
              Contact us directly by phone or text. Last-minute slots sometimes
              open up. We'll do our best to accommodate urgent needs.
            </p>
          </div>

          <div>
            <p
              style="color: var(--gold); font-weight: 500; margin-bottom: 0.5rem;"
            >
              Can you shoot in Cypress or other areas?
            </p>
            <p class="body-sm" style="color: var(--muted);">
              Absolutely. We serve all of Greater Houston. If you're outside our
              primary service area, we may add a travel fee but will always
              quote you transparently.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
