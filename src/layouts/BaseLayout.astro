---
interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  noIndex?: boolean;
  extraStyles?: string[];
}

const {
  title,
  description,
  canonical = "https://niopictures.com/",
  ogImage = "https://niopictures.com/assets/images/og-home.webp",
  noIndex = false,
  extraStyles = [],
} = Astro.props;

const currentYear = new Date().getFullYear();

const businessSchema = {
  "@context": "https://schema.org",
  "@type": ["Photographer", "LocalBusiness"],
  "@id": "https://niopictures.com/#business",
  name: "NiO Pictures",
  description:
    "NiO Pictures is a Katy, Texas photography studio specializing in event photography and heirloom family photography across Katy, Houston, Sugar Land, and Richmond.",
  url: "https://niopictures.com/",
  telephone: "+12814093585",
  email: "niopictureskaty@gmail.com",
  image: ogImage,
  priceRange: "$$",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Katy",
    addressRegion: "TX",
    postalCode: "77449",
    addressCountry: "US",
  },
  areaServed: [
    { "@type": "City", name: "Katy" },
    { "@type": "City", name: "Houston" },
    { "@type": "City", name: "Sugar Land" },
    { "@type": "City", name: "Richmond" },
  ],
  sameAs: [
    "https://www.instagram.com/nio_pictures",
    "https://www.facebook.com/profile.php?id=61580596898855",
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta name="geo.region" content="US-TX" />
    <meta name="geo.placename" content="Katy, Texas" />
    <meta name="geo.position" content="29.7858;-95.8245" />
    <meta name="ICBM" content="29.7858, -95.8245" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="NiO Pictures" />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=DM+Sans:wght@300;400;500&family=Cinzel:wght@400;500&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=DM+Sans:wght@300;400;500&family=Cinzel:wght@400;500&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=DM+Sans:wght@300;400;500&family=Cinzel:wght@400;500&display=swap"
      />
    </noscript>

    <link rel="stylesheet" href="/assets/css/global.css" />

    <link rel="preload" as="style" href="/assets/css/components.css" />
    <link rel="stylesheet" href="/assets/css/components.css" media="print" onload="this.media='all'" />

    <link rel="preload" as="style" href="/assets/css/animations.css" />
    <link rel="stylesheet" href="/assets/css/animations.css" media="print" onload="this.media='all'" />

    <noscript>
      <link rel="stylesheet" href="/assets/css/components.css" />
      <link rel="stylesheet" href="/assets/css/animations.css" />
    </noscript>

    {
      extraStyles.map((href) => (
        <Fragment>
          <link rel="preload" as="style" href={href} />
          <link rel="stylesheet" href={href} media="print" onload="this.media='all'" />
        </Fragment>
      ))
    }

    <link rel="icon" type="image/svg+xml" href="/assets/images/favicon.svg" />
    <meta name="theme-color" content="#161412" />

    <script type="application/ld+json" is:inline set:html={JSON.stringify(businessSchema)}></script>
    <slot name="head" />

    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      window.addEventListener("load", () => {
        let analyticsLoaded = false;
        const interactionEvents = ["pointerdown", "keydown", "submit"];

        const loadAnalytics = () => {
          if (analyticsLoaded) return;
          analyticsLoaded = true;
          interactionEvents.forEach((eventName) => {
            window.removeEventListener(eventName, loadAnalytics, true);
          });

          const script = document.createElement("script");
          script.src = "https://www.googletagmanager.com/gtag/js?id=G-1VZ3GPSWGH";
          script.async = true;
          document.head.appendChild(script);
          gtag("js", new Date());
          gtag("config", "G-1VZ3GPSWGH");
        };

        interactionEvents.forEach((eventName) => {
          window.addEventListener(eventName, loadAnalytics, { once: true, capture: true, passive: true });
        });
      }, { once: true });
    </script>
  </head>
  <body>
    <div id="main-content"></div>
    <slot />

    <footer class="footer" role="contentinfo">
      <div class="container">
        <div class="footer-grid">
          <div class="footer-brand">
            <a href="/" class="nav-logo">Ni<span>O</span> Pictures</a>
            <p>
              Cinematic photography for life's most meaningful moments. Based in Katy, TX
              - serving Katy first, then Cypress, Houston, Sugar Land, and Richmond.
            </p>
          </div>

          <div>
            <p class="footer-heading">Services</p>
            <nav class="footer-links" aria-label="Service links">
              <a href="/event-photography-katy-tx.html">Event Photography</a>
              <a href="/family-photography-katy-tx.html">Family Sessions</a>
              <a href="/blog.html">Blog</a>
              <a href="/portfolio.html">Portfolio</a>
              <a href="https://niopictures.pixieset.com/" target="_blank" rel="noopener noreferrer">View Gallery</a>
            </nav>
          </div>

          <div>
            <p class="footer-heading">Navigate</p>
            <nav class="footer-links" aria-label="Site links">
              <a href="/about.html">About</a>
              <a href="/book.html">Book a Session</a>
              <a href="/contact.html">Contact</a>
            </nav>
          </div>

          <div>
            <p class="footer-heading">Locations</p>
            <nav class="footer-links">
              <a href="/katy-tx-photographer.html">Katy TX</a>
              <a href="/cypress-tx-photographer.html">Cypress TX</a>
              <a href="/sugar-land-photographer.html">Sugar Land</a>
              <a href="/richmond-tx-photographer.html">Richmond TX</a>
            </nav>
          </div>

          <div class="footer-contact">
            <p class="footer-heading">Contact</p>
            <p>
              Katy, Texas<br />
              Serving Greater Houston Area<br />
              Katy - Cypress - Sugar Land - Richmond - Houston
            </p>
            <p style="margin-top: 1rem; line-height: 2.2;">
              <a href="tel:2814093585" style="display:block;">Phone 281-409-3585</a>
              <a href="mailto:niopictureskaty@gmail.com" style="display:block;">Email niopictureskaty@gmail.com</a>
              <a href="https://niopictures.pixieset.com/booking/" target="_blank" rel="noopener noreferrer" style="display:block;">Book Online</a>
            </p>
          </div>
        </div>

        <div style="border-top:1px solid var(--border-light);padding:1rem 0;margin-bottom:1rem;">
          <p style="font-size:0.75rem;color:var(--muted-dark);line-height:1.6;">
            This site uses Google Analytics to understand how visitors use our pages. No personal data is sold.
            <a href="/privacy.html" style="color:var(--muted);">Privacy Policy</a>
            &middot;
            <a href="/terms.html" style="color:var(--muted);">Terms</a>
          </p>
        </div>

        <div class="footer-bottom">
          <p class="footer-copy">&copy; {currentYear} <span>NiO Pictures</span> - Palanivel. All rights reserved. Katy, TX.</p>
          <div class="footer-legal">
            <a href="/privacy.html">Privacy</a>
            <a href="/terms.html">Terms</a>
          </div>
        </div>
      </div>
    </footer>

    <!-- Chat Bubble -->
    <div class="chat-bubble" id="chat-bubble" aria-live="polite">
      <div class="chat-popup" id="chat-popup" role="dialog" aria-label="Contact options" aria-hidden="true">
        <p class="chat-popup-title">Let's talk</p>
        <p class="chat-popup-text">We'd love to hear about your upcoming session. Reach out any way you like.</p>
        <nav class="chat-popup-actions" aria-label="Contact links">
          <a href="/book.html">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            Book a Session
          </a>
          <a href="/contact.html">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            Send a Message
          </a>
          <a href="mailto:niopictureskaty@gmail.com">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            Email Us
          </a>
          <a href="tel:2814093585">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.8a16 16 0 0 0 6 6l.9-.9a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 21.6 16z"/></svg>
            Call 281-409-3585
          </a>
        </nav>
      </div>
      <button class="chat-btn" aria-label="Open contact options" aria-expanded="false" aria-controls="chat-popup">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
        </svg>
      </button>
    </div>

    <script src="/assets/js/main.js" defer></script>
    <script src="/assets/js/chat-bubble.js" defer></script>
    <script is:inline>
      window.addEventListener("load", () => {
        let chatLoaded = false;
        const interactionEvents = ["pointerdown", "keydown"];
        const shouldLoadChat = window.location.pathname === "/contact.html" || window.location.pathname === "/book.html";

        if (!shouldLoadChat) {
          return;
        }

        const loadChat = () => {
          if (chatLoaded) return;
          chatLoaded = true;
          interactionEvents.forEach((eventName) => {
            window.removeEventListener(eventName, loadChat, true);
          });

          const chatScript = document.createElement("script");
          chatScript.src = "https://chat.niopictures.com/widget.js";
          chatScript.defer = true;
          document.body.appendChild(chatScript);
        };

        interactionEvents.forEach((eventName) => {
          window.addEventListener(eventName, loadChat, { once: true, capture: true, passive: true });
        });
      }, { once: true });
    </script>
  </body>
</html>
