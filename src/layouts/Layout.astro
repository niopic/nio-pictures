---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  noIndex?: boolean;
}

const { title, description, canonical, ogImage, noIndex } = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  ogImage={ogImage}
  noIndex={noIndex}
>
  <slot name="head" slot="head" />
  <slot />
</BaseLayout>
